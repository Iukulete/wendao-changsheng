{
  "schema_version": 1,
  "art_direction": {
    "style": "主角延续现有精致唯美的高端风格化仙侠游戏CG，只提升精度、材质、光影和构图适配；其他时代资源保持可信材质与一致的叙事完成度",
    "identity_rule": "同一角色跨立绘与分镜必须保持视觉身份稳定；露脸角色锁定脸型、五官、发型和核心饰物，兜帽男主锁定遮眼比例、侧背轮廓、织锦披风、深青流苏与黑白轮回玉，不重新猜测正脸",
    "cast_distinction_rule": "所有具名角色和群像成员都必须具备主角级辨识度；不同角色在脸型与五官比例、发式或头部轮廓、服装大轮廓、主色块、姿态和核心道具中至少明确区分四项，并在104x154小头像下不能只靠左右位置、年龄或换色辨认",
    "apparent_age_rule": "修仙者的视觉年龄由境界、种族、修行状态和剧情决定，不按实际岁数机械衰老；高境界长生角色可保持年轻外貌，以眼神、气场、姿态和身份细节表达阅历",
    "wardrobe_rule": "服装必须可穿着、符合行动功能与时代技术；低胸、贴身剪裁、胸腰强调和诱惑性设计可用于明确成年的妖族、魔女或剧情需要的角色，教廷、监察、医修与执律角色则按职责选择端庄或功能性轮廓；只禁止身份错位、时代错置、无动机拼贴、未成年性化和露骨色情",
    "regional_influences": {
      "policy": "open_regional_palette",
      "statement": "中、日、韩及其他地域的服饰、纹样、发型、建筑和构图语言都可使用，前提是经过研究、与角色身份及故事时代协调，并且不复刻已知IP",
      "rejection_basis": "只按身份冲突、时代错置、无动机拼贴、技术违和或已知IP复刻拒绝，不以国籍或地域标签作为负向词"
    },
    "forbidden": [
      "与角色身份、故事时代或指定场景语境冲突的服装与符号拼贴",
      "未经叙事支持的现代制服或影楼化造型",
      "低细节模板五官与塑料皮肤",
      "与角色身份和剧情无关的裸露或比例夸张、未成年性化与露骨色情",
      "画面文字、签名、水印与伪造汉字",
      "不遵守具名角色的脸部或兜帽身份契约",
      "已知动画、游戏或影视IP的脸、服装、动作、构图或标识复刻",
      "同一张脸冒充不同具名角色"
    ]
