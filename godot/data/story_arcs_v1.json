    {
      "id": "jade",
      "name": "旧玉",
      "scene": "res://art/scenes/void_threshold_temple.png",
      "portrait": "res://art/portraits/protagonist_hooded_close.jpg",
      "portrait_name": "玉中旧影",
      "portrait_title": "只保存选择，不替今生作答",
      "character_id": "protagonist",
      "motion_profile": "introspective",
      "portrait_mode": "focus",
      "main": [
        {"id": "jade_main_1", "title": "【旧玉·一】夜半微温", "description": "夜半醒来，黑白旧玉第一次在无人触碰时自行发温。窗纸上映出两道互不相容的影子：一道像今生，一道像尚未发生的死局。", "next": "jade_main_2", "art": {"motion_profile": "spectral"}},
        {"id": "jade_main_2", "title": "【旧玉·二】镜中旧名", "description": "旧玉把你的脸映成一个陌生旧名。那名字没有完整记忆，只有近乎本能的警惕，像有人曾用它欠下无法结清的因果。", "next": "jade_main_3", "art": {"motion_profile": "introspective"}},
        {"id": "jade_main_3", "title": "【旧玉·三】生死回响", "description": "一次险境后，旧玉没有替你挡灾，只把生死之间那一瞬完整留住。它保存的不是答案，而是每次取舍留下的轮廓。", "next": "jade_main_4", "art": {"motion_profile": "vigilant"}},
        {"id": "jade_main_4", "title": "【旧玉·终】不借旧我", "description": "旧玉终于托起足够多的回响，像要让过去替你决定今生。真正的终局，是决定哪些旧意可以留下，哪些必须止于此世。", "next": "legacy", "art": {"motion_profile": "confrontation"}}
      ],
      "echo": [
        {"id": "jade_echo_1", "title": "【定局续章·旧玉一】旧梦证词", "description": "轮回玉吐出一段可被现实核验的旧梦。梦里的人认得你，今生的人却说那段往事根本不存在。", "next": "jade_echo_2", "art": {"motion_profile": "spectral"}},
        {"id": "jade_echo_2", "title": "【定局续章·旧玉二】伪忆歧路", "description": "两段互相矛盾的记忆同时显真。真正危险的不是忘记过去，而是把一段伪忆当成自己的意志。", "next": "jade_echo_3", "art": {"motion_profile": "spectral"}},
        {"id": "jade_echo_3", "title": "【定局续章·旧玉终】玉中自证", "description": "旧玉把前世证词与今生经历并列放在面前。你必须决定谁能作证，谁只能留下痕迹。", "next": "resolution", "art": {"motion_profile": "confrontation"}}
      ],
      "main_choices": [
        {"text": "握玉静听", "outcome": "你允许旧梦提供证词，却要求每一处细节接受今生事实的核验。", "deltas": {"exp": 84, "dao_heart": 3}, "path_deltas": {"insight": 3, "bonds": 1}, "resolution": "旧我为证"},
        {"text": "以今证旧", "outcome": "你逐条比对梦兆与现实，只保留能够解释当下的部分。", "deltas": {"exp": 62, "karma": 5}, "path_deltas": {"insight": 2, "defiance": 2}, "resolution": "今生校旧"},
        {"text": "封住梦兆", "outcome": "你不销毁过去，只切断它替今生发号施令的权力。", "deltas": {"dao_heart": 6, "hp": -8}, "path_deltas": {"defiance": 3, "ambition": 1}, "resolution": "封梦自持"}
      ],
      "echo_choices": [
        {"text": "承认旧证", "outcome": "两世证词被并排保存，旧我可以作证，却不能越俎代庖。", "deltas": {"exp": 96, "dao_heart": 4}, "path_deltas": {"bonds": 2, "insight": 2}, "resolution": "守证旧我"},
        {"text": "以今校旧", "outcome": "今生经历成为旧忆的锚点，任何回响都必须先通过现实。", "deltas": {"exp": 74, "karma": 6}, "path_deltas": {"insight": 3, "defiance": 1}, "resolution": "今身定锚"},
        {"text": "留痕断梦", "outcome": "过去被允许留痕，却永远失去替今生下令的资格。", "deltas": {"dao_heart": 8, "hp": -10}, "path_deltas": {"defiance": 4}, "resolution": "断梦留痕"}
      ],
      "legacy_birth_effects": {"旧我为证": {"exp": 18, "dao_heart": 3}, "今生校旧": {"dao_heart": 5}, "封梦自持": {"dao_heart": 7}},
      "echo_birth_effects": {"守证旧我": {"exp": 15}, "今身定锚": {"dao_heart": 2}, "断梦留痕": {"dao_heart": 3}}
    },
    {
