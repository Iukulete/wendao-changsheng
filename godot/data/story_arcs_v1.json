        {"id": "sect_echo_2", "title": "【定局续章·山门二】两代门规", "description": "旧门规与今世山门的制度发生冲突。两边都声称是在保护你，也都想借你证明自己更正统。", "next": "sect_echo_3", "art": {"motion_profile": "confrontation"}},
        {"id": "sect_echo_3", "title": "【定局续章·山门终】道统归属", "description": "两代山门同时要求明确归属。真正的问题不是选哪块牌匾，而是谁有权替你解释道统。", "next": "resolution", "art": {"motion_profile": "restrained"}}
      ],
      "main_choices": [
        {"text": "据理受验", "outcome": "你逐条回应质疑，不借天资压人，也不让门规替旁人定罪。", "deltas": {"exp": 82, "reputation": 5}, "path_deltas": {"insight": 2, "bonds": 2}, "resolution": "守律立道"},
        {"text": "借师承入局", "outcome": "你承认师承给过机会，却没有把全部责任推给长辈。", "deltas": {"exp": 64, "spirit_stones": 8}, "path_deltas": {"bonds": 3, "ambition": 1}, "resolution": "师承共担"},
        {"text": "拒绝被定价", "outcome": "你要求把规则与代价写明，第一次以自己的名字站在山门前。", "deltas": {"dao_heart": 6, "reputation": -2}, "path_deltas": {"defiance": 3, "creation": 1}, "resolution": "自立道统"}
      ],
      "echo_choices": [
        {"text": "续写旧律", "outcome": "你保留旧律中真正能护人的部分，并把旧宗也纳入问责。", "deltas": {"exp": 94, "reputation": 7}, "path_deltas": {"insight": 2, "bonds": 2}, "resolution": "旧律新章"},
        {"text": "与今门共议", "outcome": "两代山门公开核对权利与代价，道统第一次不再等同于服从。", "deltas": {"spirit_stones": 12, "karma": 5}, "path_deltas": {"bonds": 4}, "resolution": "两代同门"},
        {"text": "另立新章", "outcome": "你只承认自己愿意承担的道统，并为它写下可被后人质疑的新章。", "deltas": {"dao_heart": 8, "enmity": 3}, "path_deltas": {"defiance": 3, "creation": 2}, "resolution": "今世开宗"}
      ],
      "legacy_birth_effects": {"守律立道": {"reputation": 5}, "师承共担": {"reputation": 3, "dao_heart": 2}, "自立道统": {"dao_heart": 4, "enmity": 2}},
      "echo_birth_effects": {"旧律新章": {"reputation": 2}, "两代同门": {"reputation": 1, "dao_heart": 1}, "今世开宗": {"dao_heart": 2}}
