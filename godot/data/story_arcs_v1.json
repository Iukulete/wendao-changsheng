        {"text": "养恩为先", "outcome": "血脉被留下查证，但真正养育今生的人先得到回答。", "deltas": {"reputation": 9, "dao_heart": 4}, "path_deltas": {"compassion": 3, "bonds": 2}, "resolution": "养恩为先"},
        {"text": "去名留义", "outcome": "你放下可以换取位置的旧名，只保留仍愿意承担彼此的关系。", "deltas": {"dao_heart": 9, "spirit_stones": -6}, "path_deltas": {"defiance": 3, "compassion": 1}, "resolution": "去名留义"}
      ],
      "legacy_birth_effects": {"承认旧脉": {"family_fame": 10, "family_wealth": 3}, "护亲问源": {"reputation": 3, "family_wealth": 2}, "断名自立": {"dao_heart": 3}},
      "echo_birth_effects": {"祖脉共担": {"family_wealth": 1}, "养恩为先": {"reputation": 2}, "去名留义": {"dao_heart": 2}}
