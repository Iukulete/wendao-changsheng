        {"id": "family_echo_2", "title": "【定局续章·家世二】养恩与血脉", "description": "血脉证据与养育之恩被摆到同一张案上。任何一方被轻易抹去，都会让另一方变成新的枷锁。", "next": "family_echo_3", "art": {"motion_profile": "introspective"}},
        {"id": "family_echo_3", "title": "【定局续章·家世终】旧名裁决", "description": "旧名、祖脉和养育者共同到场。你要留下的不只是姓氏，而是一套今后仍能承担后果的关系。", "next": "resolution", "art": {"motion_profile": "confrontation"}}
      ],
      "main_choices": [
        {"text": "追查旧账", "outcome": "你查清一部分真相，也把一部分债正式记到自己名下。", "deltas": {"exp": 86, "spirit_stones": 8}, "path_deltas": {"insight": 3, "ambition": 1}, "resolution": "承认旧脉"},
