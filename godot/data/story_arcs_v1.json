      "character_id": "sect_lawkeepers",
      "motion_profile": "restrained",
      "portrait_mode": "focus",
      "main": [
        {"id": "sect_main_1", "title": "【山门·一】测灵余波", "description": "测灵台上的结果已经传遍山门。有人把你当成值得下注的苗子，也有人认为你的家世、旧玉与灵根都该先被审查。", "next": "sect_main_2", "art": {"motion_profile": "restrained"}},
        {"id": "sect_main_2", "title": "【山门·二】外院名额", "description": "外院名额忽然少了一席，执事说是资源不足，几名同辈却知道有人在用名额试你的软硬。", "next": "sect_main_3", "art": {"motion_profile": "vigilant"}},
        {"id": "sect_main_3", "title": "【山门·三】掌律问心", "description": "掌律玉简把早年的每次选择串成一份问心案卷。一脉长老要证明你只是靠师承庇护才走到今天。", "next": "sect_main_4", "art": {"motion_profile": "confrontation"}},
        {"id": "sect_main_4", "title": "【山门·终】自择道统", "description": "山门愿意给你更高的位置，代价是让某一脉替你定义道途。走到这一步，你必须决定自己属于谁，又不属于谁。", "next": "legacy", "art": {"motion_profile": "restrained"}}
      ],
      "echo": [
